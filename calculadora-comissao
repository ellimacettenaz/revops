                    <div style={{ display: "flex", alignItems: "center", gap: 8, marginBottom: 14 }}>
                      <div style={{ width: 10, height: 10, borderRadius: "50%", background: COLORS[id] }} />
                      <span style={{ fontSize: 12, fontWeight: 700, color: COLORS[id], textTransform: "uppercase", letterSpacing: 0.5 }}>{MODELS.find(m => m.id === id).label}</span>
                      {rec?.modeloRec === id && <span style={{ fontSize: 10, background: BG[id], color: COLORS[id], padding: "1px 7px", borderRadius: 10, fontWeight: 600 }}>recomendado</span>}
                    </div>
                    <div style={{ fontSize: 11, color: "#94a3b8", fontWeight: 600, textTransform: "uppercase", letterSpacing: 0.8, marginBottom: 4 }}>Total do mês</div>
                    <div style={{ fontFamily: "'Lora', serif", fontSize: 28, fontWeight: 700, color: COLORS[id], marginBottom: 14 }}>{fmt(r.total)}</div>
                    <div style={{ display: "flex", justifyContent: "space-between", fontSize: 13, color: "#64748b", marginBottom: 6 }}>
                      <span>Salário fixo</span><span style={{ fontWeight: 500 }}>{fmt(fixo)}</span>
                    </div>
                    <div style={{ display: "flex", justifyContent: "space-between", fontSize: 13, marginBottom: 18 }}>
                      <span style={{ color: "#64748b" }}>Comissão</span><span style={{ color: COLORS[id], fontWeight: 600 }}>{fmt(r.comissao)}</span>
                    </div>
                    <div style={{ fontSize: 11, color: "#94a3b8", display: "flex", justifyContent: "space-between", marginBottom: 5 }}>
                      <span style={{ display: "flex", alignItems: "center" }}>vs OTE <Tip text={`OTE neste modelo é ${fmt(oteVal)} — ganho total esperado na meta.`} /></span>
                      <span style={{ color: COLORS[id], fontWeight: 600 }}>{fmtPct(r.total / oteVal)}</span>
                    </div>
                    <div style={{ height: 5, background: "#f1f5f9", borderRadius: 3, overflow: "hidden", marginBottom: 16 }}>
                      <div style={{ height: "100%", width: `${ratio * 100}%`, background: COLORS[id], borderRadius: 3, transition: "width .3s" }} />
                    </div>
                    {/* Custo empresa */}
                    <div style={{ borderTop: "1.5px solid #f1f5f9", paddingTop: 12 }}>
                      <div style={{ display: "flex", alignItems: "center", fontSize: 10, color: "#94a3b8", fontWeight: 600, textTransform: "uppercase", letterSpacing: 0.5, marginBottom: 8 }}>
                        Custo pra empresa <Tip text="Fixo com encargos CLT (~70%) + comissão. Estimativa — consulte seu contador." />
                      </div>
                      <div style={{ display: "flex", justifyContent: "space-between", fontSize: 12, color: "#64748b", marginBottom: 4 }}>
                        <span>Fixo + encargos</span>
                        <span style={{ fontWeight: 500 }}>{fmt(fixo * 1.7)}</span>
                      </div>
                      <div style={{ display: "flex", justifyContent: "space-between", fontSize: 12, marginBottom: 4 }}>
                        <span style={{ color: "#64748b" }}>Comissão</span>
                        <span style={{ fontWeight: 500 }}>{fmt(r.comissao)}</span>
                      </div>
                      <div style={{ display: "flex", justifyContent: "space-between", fontSize: 13, borderTop: "1px solid #f1f5f9", paddingTop: 6, marginTop: 2 }}>
                        <span style={{ fontWeight: 600, color: "#475569" }}>Total empresa</span>
                        <span style={{ fontWeight: 700, color: "#1e293b" }}>{fmt(fixo * 1.7 + r.comissao)}</span>
                      </div>
                      <div style={{ display: "flex", justifyContent: "space-between", fontSize: 11, color: "#94a3b8", marginTop: 6 }}>
                        <span style={{ display: "flex", alignItems: "center" }}>% da receita <Tip text="Quanto da receita gerada vai pra remunerar o vendedor. Ideal: 8–20% dependendo do segmento." /></span>
                        <span style={{ fontWeight: 600 }}>{receitaVal > 0 ? ((fixo * 1.7 + r.comissao) / receitaVal * 100).toFixed(1) : "—"}%</span>
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>

            {active.length > 0 && (
              <div style={cardStyle}>
                <div style={{ fontSize: 14, fontWeight: 700, marginBottom: 4 }}>Curva de ganhos por atingimento</div>
                <div style={{ fontSize: 12.5, color: "#94a3b8", lineHeight: 1.6, marginBottom: 24 }}>Salário total do vendedor em cada nível de atingimento. À direita da linha azul, ele superou a meta.</div>
                <svg width="100%" viewBox={`0 0 680 ${chartH + 50}`} style={{ overflow: "visible" }}>
                  {[0, 0.25, 0.5, 0.75, 1].map((t, i) => (
                    <g key={i}>
                      <line x1={0} y1={chartH - t * chartH} x2={680} y2={chartH - t * chartH} stroke="#f1f5f9" strokeWidth={1} />
                      <text x={-4} y={chartH - t * chartH + 4} textAnchor="end" fill="#cbd5e1" fontSize={9}>{fmt(maxY * t)}</text>
                    </g>
                  ))}
                  {active.map(id => {
                    const pts = curve.map((d, i) => `${(i / (curve.length - 1)) * 680},${chartH - (d[id] / maxY) * chartH}`).join(" ");
                    return <polyline key={id} points={pts} fill="none" stroke={COLORS[id]} strokeWidth={2.5} strokeLinejoin="round" />;
                  })}
                  {(() => {
                    const mx = (ATH_LEVELS.indexOf(1.0) / (ATH_LEVELS.length - 1)) * 680;
                    return <g><line x1={mx} y1={0} x2={mx} y2={chartH} stroke="#3b82f6" strokeWidth={1.5} strokeDasharray="5,4" /><text x={mx} y={-8} textAnchor="middle" fill="#3b82f6" fontSize={10} fontWeight="600">meta</text></g>;
                  })()}
                  {ATH_LEVELS.map((a, i) => <text key={i} x={(i / (ATH_LEVELS.length - 1)) * 680} y={chartH + 20} textAnchor="middle" fill="#94a3b8" fontSize={10}>{fmtPct(a)}</text>)}
                  <text x={340} y={chartH + 38} textAnchor="middle" fill="#cbd5e1" fontSize={10}>atingimento da quota</text>
                </svg>
                <div style={{ display: "flex", gap: 20, marginTop: 16, flexWrap: "wrap" }}>
                  {active.map(id => (
                    <div key={id} style={{ display: "flex", alignItems: "center", gap: 6, fontSize: 12, color: "#64748b" }}>
                      <div style={{ width: 18, height: 3, background: COLORS[id], borderRadius: 2 }} />
                      {MODELS.find(m => m.id === id).label}
                    </div>
                  ))}
                  <div style={{ display: "flex", alignItems: "center", gap: 6, fontSize: 12, color: "#94a3b8" }}>
                    <div style={{ width: 18, borderTop: "2px dashed #3b82f6" }} />
                    Meta (100%)
                  </div>
                </div>
              </div>
            )}
            <div style={{ marginTop: 24 }}>
              <button onClick={() => setTela("plano")} style={{ background: "#fff", color: "#64748b", border: "1.5px solid #e2e8f0", padding: "11px 28px", borderRadius: 8, cursor: "pointer", fontFamily: "inherit", fontSize: 13, fontWeight: 500 }}>
                ← Ajustar o plano
              </button>
            </div>

            {/* Card de análise */}
            {active.length > 0 && (() => {
              const melhor = active.reduce((a, b) => res[a].total >= res[b].total ? a : b);
              const maisBarato = active.reduce((a, b) => (fixo * 1.7 + res[a].comissao) <= (fixo * 1.7 + res[b].comissao) ? a : b);
              const insights = [];

              if (ating < 0.75) {
                insights.push("⚠️ Abaixo de 75% da quota — o vendedor provavelmente está desmotivado. Revise se a meta é atingível ou se o suporte ao vendedor é suficiente.");
              } else if (ating >= 1 && ating < 1.25) {
                insights.push("✅ Na zona da meta — o plano está funcionando como esperado.");
              } else if (ating >= 1.25) {
                insights.push("🚀 Acima de 125% — o vendedor está acelerando. Verifique se o custo pra empresa ainda está dentro da margem aceitável.");
              }

              if (active.includes("acelerador") && ating >= threshold) {
                insights.push(`💡 O acelerador está ativo neste nível (${fmtPct(ating)}). A comissão extra está recompensando a superação da meta.`);
              }

              const custoPctReceita = receitaVal > 0 ? ((fixo * 1.7 + res[melhor].comissao) / receitaVal * 100) : 0;
              if (custoPctReceita > 25) {
                insights.push(`🔴 O custo de remuneração está em ${custoPctReceita.toFixed(1)}% da receita — acima do recomendado. Considere aumentar a quota ou reduzir o percentual de comissão.`);
              } else if (custoPctReceita > 0 && custoPctReceita <= 15) {
                insights.push(`🟢 Custo de remuneração em ${custoPctReceita.toFixed(1)}% da receita — dentro de uma faixa saudável.`);
              }

              return (
                <div style={{ ...cardStyle, marginTop: 20, borderLeft: "4px solid #3b82f6" }}>
                  <div style={{ fontSize: 14, fontWeight: 700, color: "#1e293b", marginBottom: 16 }}>📊 Análise do plano</div>

                  <div style={{ display: "grid", gridTemplateColumns: active.length > 1 ? "1fr 1fr" : "1fr", gap: 12, marginBottom: 20 }}>
                    {active.length > 1 && (
                      <>
                        <div style={{ background: BG[melhor], borderRadius: 10, padding: "12px 14px" }}>
                          <div style={{ fontSize: 10, color: COLORS[melhor], fontWeight: 700, textTransform: "uppercase", letterSpacing: 0.5, marginBottom: 4 }}>Maior ganho pro vendedor</div>
                          <div style={{ fontSize: 15, fontWeight: 700, color: "#1e293b" }}>{MODELS.find(m => m.id === melhor)?.label}</div>
                          <div style={{ fontSize: 12, color: "#64748b", marginTop: 2 }}>{fmt(res[melhor].total)} neste cenário</div>
                        </div>
                        <div style={{ background: "#f0fdf4", borderRadius: 10, padding: "12px 14px" }}>
                          <div style={{ fontSize: 10, color: "#047857", fontWeight: 700, textTransform: "uppercase", letterSpacing: 0.5, marginBottom: 4 }}>Menor custo pra empresa</div>
                          <div style={{ fontSize: 15, fontWeight: 700, color: "#1e293b" }}>{MODELS.find(m => m.id === maisBarato)?.label}</div>
                          <div style={{ fontSize: 12, color: "#64748b", marginTop: 2 }}>{fmt(fixo * 1.7 + res[maisBarato].comissao)} neste cenário</div>
                        </div>
                      </>
                    )}
                  </div>

                  <div style={{ display: "flex", flexDirection: "column", gap: 10 }}>
                    {insights.map((ins, i) => (
                      <div key={i} style={{ fontSize: 13, color: "#475569", lineHeight: 1.6, background: "#f8fafc", borderRadius: 8, padding: "10px 14px" }}>{ins}</div>
                    ))}
                  </div>
                </div>
              );
            })()}
          </div>
        )}
      </div>
    </div>
  );
}


    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<App />);
  </script>
</body>
</html>
