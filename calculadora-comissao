<body>
  <div id="root"></div>
  <script type="text/babel">
    const { useState, useMemo } = React;


const fmt = (v) => v.toLocaleString("pt-BR", { style: "currency", currency: "BRL", maximumFractionDigits: 0 });
const fmtPct = (v) => `${(v * 100).toFixed(0)}%`;

// ─── Cálculos ───────────────────────────────────────────────────────────────
function calcFlat({ fixo, pctFlat, receita }) {
  const c = receita * (pctFlat / 100);
  return { comissao: c, total: fixo + c };
}
function calcAcel({ quota, fixo, pctBase, pctAcel, threshold, receita }) {
  const base = Math.min(receita, quota * threshold) * (pctBase / 100);
  const extra = Math.max(0, receita - quota * threshold) * (pctAcel / 100);
  return { comissao: base + extra, total: fixo + base + extra };
}
function calcFaixas({ quota, fixo, faixas, receita }) {
  const a = receita / quota;
  let p = 0;
  for (const f of faixas) { if (a >= f.min) p = f.pct; }
  const c = receita * (p / 100);
  return { comissao: c, total: fixo + c };
}

// ─── Perguntas do modo guiado ────────────────────────────────────────────────
const QUESTIONS = [
  {
    id: "segmento",
    pergunta: "Qual é o segmento da sua empresa?",
    ajuda: "Isso nos ajuda a sugerir percentuais de comissão compatíveis com o mercado.",
    opcoes: [
      { valor: "saas", label: "SaaS / Software", emoji: "💻", desc: "Ex: sistemas de gestão, plataformas, ferramentas B2B" },
      { valor: "servicos", label: "Serviços / Consultoria", emoji: "🤝", desc: "Ex: agências, escritórios, empresas de RH, contabilidade" },
      { valor: "industria", label: "Indústria / Distribuição", emoji: "🏭", desc: "Ex: distribuidoras, atacadistas, fabricantes" },
      { valor: "varejo", label: "Varejo / E-commerce", emoji: "🛒", desc: "Ex: lojas físicas, marketplaces, direct-to-consumer" },
      { valor: "outro", label: "Outro", emoji: "📦", desc: "Ex: saúde, educação, imóveis, financeiro" },
    ],
  },
  {
    id: "ciclo",
    pergunta: "Como é o ciclo de venda?",
    ajuda: "Ciclos longos geralmente pedem comissões maiores por negócio. Ciclos curtos permitem volume.",
    opcoes: [
      { valor: "curto", label: "Curto (dias)", emoji: "⚡", desc: "O cliente decide rápido" },
      { valor: "medio", label: "Médio (semanas)", emoji: "📅", desc: "Algumas reuniões até fechar" },
      { valor: "longo", label: "Longo (meses)", emoji: "🗓️", desc: "Processo estruturado, vários decisores" },
    ],
  },
  {
    id: "ticket",
    pergunta: "Qual é o ticket médio por venda?",
    ajuda: "Ticket médio é o valor típico de cada negócio fechado. Isso define a quota e o potencial de ganho.",
    opcoes: [
      { valor: "baixo", label: "Até R$ 5.000", emoji: "💰", desc: "Venda transacional" },
      { valor: "medio", label: "R$ 5k – R$ 50k", emoji: "💰💰", desc: "Venda consultiva" },
      { valor: "alto", label: "Acima de R$ 50k", emoji: "💰💰💰", desc: "Venda enterprise / complexa" },
    ],
  },
  {
    id: "experiencia",
    pergunta: "Qual o perfil do vendedor que você vai contratar?",
    ajuda: "O nível de experiência influencia o salário fixo e o quanto de variável faz sentido oferecer.",
    opcoes: [
      { valor: "junior", label: "Júnior", emoji: "🌱", desc: "Pouca ou nenhuma experiência em vendas" },
      { valor: "pleno", label: "Pleno", emoji: "🌿", desc: "2–4 anos de experiência" },
      { valor: "senior", label: "Sênior", emoji: "🌳", desc: "5+ anos, já tem carteira" },
    ],
  },
  {
    id: "objetivo",
    pergunta: "Qual é o principal objetivo com esse vendedor?",
    ajuda: "Isso define se faz mais sentido incentivar volume, grandes negócios ou consistência.",
    opcoes: [
      { valor: "volume", label: "Fechar muitos negócios", emoji: "🎯", desc: "Quantidade é o foco" },
      { valor: "crescimento", label: "Crescer contas existentes", emoji: "📈", desc: "Expansão e upsell" },
      { valor: "novos", label: "Abrir novos clientes", emoji: "🚀", desc: "Prospecção e conquista" },
    ],
  },
];

// ─── Lógica de recomendação ──────────────────────────────────────────────────
function gerarRecomendacao(respostas) {
  const { segmento, ciclo, ticket, experiencia, objetivo } = respostas;

  // Fixo base por nível
  const fixoBase = { junior: 3000, pleno: 5000, senior: 8000 }[experiencia] || 5000;

  // Quota: baseada no ticket e ciclo
  const ticketRef = { baixo: 3000, medio: 20000, alto: 80000 }[ticket] || 20000;
  const negMes = { curto: 15, medio: 5, longo: 2 }[ciclo] || 5;
  const quota = ticketRef * negMes;

  // Pct flat de referência por segmento
  const pctFlatRef = {
    saas: 8, servicos: 10, industria: 5, varejo: 3, outro: 6,
  }[segmento] || 6;

  // Modelo recomendado
  let modeloRec, razao;
  if (ciclo === "curto" && ticket === "baixo") {
    modeloRec = "flat";
    razao = "Com ciclo curto e ticket baixo, a simplicidade do flat funciona melhor — o vendedor consegue calcular o ganho na hora e se motiva a fechar volume.";
  } else if (objetivo === "crescimento") {
    modeloRec = "faixas";
    razao = "Para crescimento de contas, faixas incentivam o vendedor a ir além da meta sem criar pressão excessiva por volume.";
  } else if (ciclo === "longo" || ticket === "alto") {
    modeloRec = "acelerador";
    razao = "Com ciclo longo ou ticket alto, aceleradores recompensam quem supera a meta — cada negócio a mais vale muito, então faz sentido pagar mais por isso.";
  } else {
    modeloRec = "acelerador";
    razao = "Aceleradores tendem a funcionar bem para a maioria dos perfis: incentivam bater a meta e recompensam quem vai além.";
  }

  // Proporção fixo/variável por experiência
  const propFixo = { junior: 0.6, pleno: 0.5, senior: 0.4 }[experiencia] || 0.5;
  const oteAlvo = fixoBase / propFixo;
  const comissaoAlvo = oteAlvo - fixoBase;
  const pctSugerido = Math.round((comissaoAlvo / quota) * 100 * 10) / 10; // resultado em %, com 1 casa decimal

  return {
    fixo: fixoBase,
    quota,
    pctFlat: pctSugerido,
    pctBase: Math.round(pctSugerido * 0.7 * 2) / 2,
    pctAcel: Math.round(pctSugerido * 1.5 * 2) / 2,
    threshold: 1.0,
    faixas: [
      { min: 0, pct: Math.round(pctSugerido * 0.5 * 2) / 2 },
      { min: 0.75, pct: Math.round(pctSugerido * 0.85 * 2) / 2 },
      { min: 1.0, pct: pctSugerido },
      { min: 1.25, pct: Math.round(pctSugerido * 1.4 * 2) / 2 },
    ],
    modeloRec,
    razao,
    propFixo,
  };
}

// ─── Constantes visuais ──────────────────────────────────────────────────────
const MODELS = [
  { id: "flat", label: "Flat", desc: "Percentual fixo sobre tudo que vender" },
  { id: "acelerador", label: "Aceleradores", desc: "% maior depois de bater o gatilho" },
  { id: "faixas", label: "Faixas", desc: "Percentual sobe conforme o atingimento" },
];
const ATH_LEVELS = [0, 0.5, 0.75, 0.9, 1.0, 1.1, 1.25, 1.5, 2.0];
const COLORS = { flat: "#b45309", acelerador: "#047857", faixas: "#4338ca" };
const BG = { flat: "#fef3c7", acelerador: "#d1fae5", faixas: "#e0e7ff" };
const BORDER = { flat: "#fde68a", acelerador: "#6ee7b7", faixas: "#a5b4fc" };

// ─── Componentes auxiliares ──────────────────────────────────────────────────
function Tip({ text }) {
  const [on, setOn] = useState(false);
  return (
    <span style={{ position: "relative", display: "inline-flex", alignItems: "center" }}>
      <span onMouseEnter={() => setOn(true)} onMouseLeave={() => setOn(false)} onClick={() => setOn(v => !v)}
        style={{ display: "inline-flex", alignItems: "center", justifyContent: "center", width: 15, height: 15, borderRadius: "50%", background: "#e2e8f0", color: "#64748b", fontSize: 9, fontWeight: 700, cursor: "pointer", marginLeft: 5, userSelect: "none" }}>?</span>
      {on && (
        <span style={{ position: "absolute", bottom: "calc(100% + 8px)", left: "50%", transform: "translateX(-50%)", background: "#1e293b", color: "#f1f5f9", fontSize: 12, padding: "10px 13px", borderRadius: 8, width: 220, lineHeight: 1.6, zIndex: 999, boxShadow: "0 8px 24px rgba(0,0,0,.2)", whiteSpace: "normal", textAlign: "left", pointerEvents: "none" }}>
          {text}
          <span style={{ position: "absolute", top: "100%", left: "50%", transform: "translateX(-50%)", border: "5px solid transparent", borderTopColor: "#1e293b" }} />
        </span>
      )}
    </span>
  );
}

function Label({ children, tip }) {
  return (
    <div style={{ display: "flex", alignItems: "center", marginBottom: 8 }}>
      <span style={{ fontSize: 11, color: "#94a3b8", letterSpacing: 0.6, textTransform: "uppercase", fontWeight: 600 }}>{children}</span>
      {tip && <Tip text={tip} />}
    </div>
  );
}

function NumInput({ value, onChange, width = "100%" }) {
  return <input type="number" value={value} onChange={e => onChange(+e.target.value)}
    style={{ background: "#fff", border: "1.5px solid #e2e8f0", color: "#1e293b", padding: "9px 12px", borderRadius: 8, fontFamily: "inherit", fontSize: 15, width, outline: "none" }} />;
}

function Slider({ value, onChange, min, max, step }) {
  return <input type="range" min={min} max={max} step={step} value={value} onChange={e => onChange(+e.target.value)}
    style={{ width: "100%", marginTop: 12, accentColor: "#3b82f6" }} />;
}

// ─── Tela do guia ────────────────────────────────────────────────────────────
function GuideScreen({ onConcluir }) {
  const [etapa, setEtapa] = useState(0);
  const [respostas, setRespostas] = useState({});
  const [saindo, setSaindo] = useState(false);

  const q = QUESTIONS[etapa];
  const total = QUESTIONS.length;
  const progresso = ((etapa) / total) * 100;

  function responder(valor) {
    const novas = { ...respostas, [q.id]: valor };
    setRespostas(novas);
    if (etapa < total - 1) {
      setSaindo(true);
      setTimeout(() => { setEtapa(e => e + 1); setSaindo(false); }, 200);
    } else {
      const rec = gerarRecomendacao(novas);
      onConcluir(rec);
    }
  }

  function voltar() {
    if (etapa > 0) { setSaindo(true); setTimeout(() => { setEtapa(e => e - 1); setSaindo(false); }, 150); }
  }

  return (
    <div style={{ minHeight: "100vh", background: "#f1f5f9", display: "flex", flexDirection: "column", alignItems: "center", justifyContent: "center", padding: "24px 20px" }}>
      <div style={{ width: "100%", maxWidth: 560 }}>

        {/* Logo */}
        <div style={{ textAlign: "center", marginBottom: 40 }}>
          <div style={{ fontFamily: "'Lora', serif", fontSize: 20, fontWeight: 700, color: "#1e293b" }}>Calculadora de Comissão</div>
          <div style={{ fontSize: 12, color: "#94a3b8", marginTop: 4 }}>Vamos montar o plano certo pra você</div>
        </div>

        {/* Progresso */}
        <div style={{ marginBottom: 32 }}>
          <div style={{ display: "flex", justifyContent: "space-between", fontSize: 12, color: "#94a3b8", marginBottom: 8 }}>
            <span>Pergunta {etapa + 1} de {total}</span>
            <span>{Math.round(((etapa) / total) * 100)}% concluído</span>
          </div>
          <div style={{ height: 4, background: "#e2e8f0", borderRadius: 2, overflow: "hidden" }}>
            <div style={{ height: "100%", width: `${progresso}%`, background: "#3b82f6", borderRadius: 2, transition: "width .4s ease" }} />
          </div>
        </div>

        {/* Card da pergunta */}
        <div style={{ background: "#fff", border: "1.5px solid #e2e8f0", borderRadius: 16, padding: "32px 28px", boxShadow: "0 4px 24px rgba(0,0,0,.06)", opacity: saindo ? 0 : 1, transform: saindo ? "translateY(8px)" : "translateY(0)", transition: "opacity .2s, transform .2s" }}>
          <div style={{ fontSize: 20, fontWeight: 700, color: "#1e293b", marginBottom: 8, lineHeight: 1.4 }}>{q.pergunta}</div>
          <div style={{ fontSize: 13.5, color: "#64748b", marginBottom: 28, lineHeight: 1.6 }}>{q.ajuda}</div>

          <div style={{ display: "flex", flexDirection: "column", gap: 10 }}>
            {q.opcoes.map(op => {
              const selecionado = respostas[q.id] === op.valor;
              return (
                <button key={op.valor} onClick={() => responder(op.valor)} style={{
                  display: "flex", alignItems: "center", gap: 14, padding: "14px 18px",
                  border: "1.5px solid", borderRadius: 10, cursor: "pointer",
                  fontFamily: "inherit", textAlign: "left", transition: "all .15s",
                  borderColor: selecionado ? "#3b82f6" : "#e2e8f0",
                  background: selecionado ? "#eff6ff" : "#fff",
                }}>
                  <span style={{ fontSize: 22 }}>{op.emoji}</span>
                  <div>
                    <div style={{ fontSize: 14, fontWeight: 600, color: selecionado ? "#1d4ed8" : "#1e293b" }}>{op.label}</div>
                    {op.desc && <div style={{ fontSize: 12, color: "#94a3b8", marginTop: 2 }}>{op.desc}</div>}
                  </div>
                  {selecionado && <span style={{ marginLeft: "auto", color: "#3b82f6", fontSize: 18 }}>✓</span>}
                </button>
              );
            })}
          </div>
        </div>

        {/* Voltar */}
        {etapa > 0 && (
          <button onClick={voltar} style={{ marginTop: 20, background: "none", border: "none", color: "#94a3b8", fontSize: 13, cursor: "pointer", fontFamily: "inherit", display: "flex", alignItems: "center", gap: 6 }}>
            ← Voltar
          </button>
        )}

        {/* Pular */}
        <div style={{ textAlign: "center", marginTop: 16 }}>
          <button onClick={() => onConcluir(gerarRecomendacao({ segmento: "saas", ciclo: "medio", ticket: "medio", experiencia: "pleno", objetivo: "novos" }))}
            style={{ background: "none", border: "none", color: "#cbd5e1", fontSize: 12, cursor: "pointer", fontFamily: "inherit" }}>
            Pular e montar manualmente →
          </button>
        </div>
      </div>
    </div>
  );
}

// ─── Tela de recomendação ─────────────────────────────────────────────────────
function RecScreen({ rec, onAceitar, onAjustar }) {
  const modelLabel = MODELS.find(m => m.id === rec.modeloRec)?.label;
  const color = COLORS[rec.modeloRec];
  const bg = BG[rec.modeloRec];
  const border = BORDER[rec.modeloRec];

  const oteVal =
    rec.modeloRec === "flat"
      ? calcFlat({ fixo: rec.fixo, pctFlat: rec.pctFlat, receita: rec.quota }).total
      : rec.modeloRec === "acelerador"
      ? calcAcel({ quota: rec.quota, fixo: rec.fixo, pctBase: rec.pctBase, pctAcel: rec.pctAcel, threshold: rec.threshold, receita: rec.quota }).total
      : calcFaixas({ quota: rec.quota, fixo: rec.fixo, faixas: rec.faixas, receita: rec.quota }).total;

  const propVariavel = Math.round((1 - rec.propFixo) * 100);

  return (
    <div style={{ minHeight: "100vh", background: "#f1f5f9", display: "flex", flexDirection: "column", alignItems: "center", justifyContent: "center", padding: "24px 20px" }}>
      <div style={{ width: "100%", maxWidth: 580 }}>

        <div style={{ textAlign: "center", marginBottom: 32 }}>
          <div style={{ fontSize: 13, color: "#94a3b8", marginBottom: 8 }}>Com base nas suas respostas</div>
          <div style={{ fontFamily: "'Lora', serif", fontSize: 26, fontWeight: 700, color: "#1e293b", lineHeight: 1.3 }}>Aqui está o plano que<br/>recomendamos pra você</div>
        </div>

        {/* Modelo recomendado */}
        <div style={{ background: bg, border: `1.5px solid ${border}`, borderRadius: 16, padding: "24px 28px", marginBottom: 16 }}>
          <div style={{ fontSize: 11, fontWeight: 600, textTransform: "uppercase", letterSpacing: 0.8, color, marginBottom: 6 }}>Modelo recomendado</div>
          <div style={{ fontSize: 22, fontWeight: 700, color, marginBottom: 10 }}>{modelLabel}</div>
          <div style={{ fontSize: 13.5, color: "#475569", lineHeight: 1.7 }}>{rec.razao}</div>
        </div>

        {/* Números sugeridos */}
        {(() => {
          const custoFixoEmpresa = rec.fixo * 1.7; // encargos CLT ~70%
          const custoTotalEmpresa = custoFixoEmpresa + (oteVal - rec.fixo); // fixo+encargos + comissão
          const pctReceitaRemuneracao = (oteVal / rec.quota) * 100;
          return (
            <div style={{ background: "#fff", border: "1.5px solid #e2e8f0", borderRadius: 16, padding: "24px 28px", marginBottom: 16 }}>
              <div style={{ fontSize: 13, fontWeight: 600, color: "#1e293b", marginBottom: 20 }}>Valores sugeridos</div>
              <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 20, marginBottom: 20 }}>
                {[
                  { label: "Salário fixo", valor: fmt(rec.fixo), tip: "Base mensal garantida, independente das vendas." },
                  { label: "Quota mensal", valor: fmt(rec.quota), tip: "Meta de vendas esperada por mês. Ajuste conforme seu mercado." },
                  { label: "OTE estimado", valor: fmt(oteVal), tip: "Ganho total esperado se o vendedor bater 100% da quota: fixo + comissão." },
                  { label: "Proporção fixo/variável", valor: `${Math.round(rec.propFixo * 100)}% / ${propVariavel}%`, tip: "Quanto do salário total é garantido versus variável. Mais variável = mais risco e mais potencial de ganho." },
                ].map(item => (
                  <div key={item.label}>
                    <div style={{ display: "flex", alignItems: "center", fontSize: 11, color: "#94a3b8", fontWeight: 600, textTransform: "uppercase", letterSpacing: 0.6, marginBottom: 4 }}>
                      {item.label} <Tip text={item.tip} />
                    </div>
                    <div style={{ fontFamily: "'Lora', serif", fontSize: 20, fontWeight: 700, color: "#1e293b" }}>{item.valor}</div>
                  </div>
                ))}
              </div>
              {/* Custo pra empresa */}
              <div style={{ borderTop: "1.5px solid #f1f5f9", paddingTop: 16 }}>
                <div style={{ display: "flex", alignItems: "center", fontSize: 11, color: "#94a3b8", fontWeight: 600, textTransform: "uppercase", letterSpacing: 0.6, marginBottom: 12 }}>
                  Custo pra empresa <Tip text="Inclui encargos trabalhistas estimados (~70% sobre o fixo para CLT). Comissão não tem encargo. Consulte seu contador para valores exatos." />
                </div>
                <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 12 }}>
                  {[
                    { label: "Fixo + encargos", valor: fmt(custoFixoEmpresa), tip: "Salário fixo com encargos CLT estimados (INSS, FGTS, férias, 13º). Aproximadamente 1,7× o salário bruto." },
                    { label: "Custo total na meta", valor: fmt(custoTotalEmpresa), tip: "Fixo com encargos + comissão. É o que a empresa desembolsa quando o vendedor bate 100% da quota." },
                    { label: "% da receita", valor: `${pctReceitaRemuneracao.toFixed(1)}%`, tip: "Percentual da receita gerada que vai para a remuneração do vendedor (OTE ÷ quota). O ideal é entre 8–20% dependendo do segmento e margem." },
                  ].map(item => (
                    <div key={item.label} style={{ background: "#f8fafc", borderRadius: 10, padding: "12px 14px" }}>
                      <div style={{ display: "flex", alignItems: "center", fontSize: 10, color: "#94a3b8", fontWeight: 600, textTransform: "uppercase", letterSpacing: 0.5, marginBottom: 6 }}>
                        {item.label} <Tip text={item.tip} />
                      </div>
                      <div style={{ fontSize: 16, fontWeight: 700, color: "#1e293b" }}>{item.valor}</div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          );
        })()}

        {/* Aviso */}
        <div style={{ background: "#fffbeb", border: "1px solid #fde68a", borderRadius: 10, padding: "12px 16px", fontSize: 12.5, color: "#92400e", lineHeight: 1.6, marginBottom: 28 }}>
          <strong>Esses valores são um ponto de partida.</strong> Ajuste conforme a realidade do seu mercado, margem do produto e o que você consegue encontrar de candidatos.
        </div>

        {/* CTAs */}
        <div style={{ display: "flex", gap: 12, flexWrap: "wrap" }}>
          <button onClick={onAceitar} style={{ flex: 1, background: "#1e293b", color: "#fff", border: "none", padding: "14px 24px", borderRadius: 10, cursor: "pointer", fontFamily: "inherit", fontSize: 14, fontWeight: 600 }}>
            Usar esses valores e simular →
          </button>
          <button onClick={onAjustar} style={{ background: "#fff", color: "#64748b", border: "1.5px solid #e2e8f0", padding: "14px 20px", borderRadius: 10, cursor: "pointer", fontFamily: "inherit", fontSize: 13, fontWeight: 500 }}>
            Ajustar manualmente
          </button>
        </div>
      </div>
    </div>
  );
}

